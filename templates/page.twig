{% extends 'templates/_document.twig' %}

{% block content %}
  {% if fn('is_front_page') %}
    {{ renderComponent('HeroHeaderHome', {'post': post}) }}
  {% else %}
    {{ renderComponent('BlockPageHeader', {'post': post}) }}
  {% endif %}
  {% if post.meta('pageComponents') %}
    {% for component in post.meta('pageComponents') %}
      {{ renderComponent(component) }}
    {% endfor %}
  {% else %}
    {# Fallback for pages whose body is injected via the_content filter,
       e.g. TutorLMS static pages (student/instructor registration, cart, checkout) #}
    <div class="tutor-wrap">
      {{ post.content }}
    </div>
  {% endif %}
{% endblock %}
